% URS-shaped PDF template — derived from the bundled elspais template,
% with the page header rewritten to match URS-v1.0's per-page identity
% block (Sponsor / Protocol / Version) and the footer rewritten to the
% "CONFIDENTIAL  Page N of M" form.
%
% Consumed by elspais pdf via --template <this file>.

\documentclass[12pt,letterpaper]{report}

% Page geometry. The bottom margin is deliberately wider than the
% left/right margins so the fancyhdr footer (`Specific to Protocol ... /
% CONFIDENTIAL / Page N of M`) clears the last body text line. The earlier
% 1in symmetric bottom margin left only ~0.5in of clearance once headheight
% (42pt) and footskip ate into it — last-line text (e.g. orphan "See:"
% lines after image floats migrated forward) ended up overlapping the
% footer rule. 1.25in bottom + 30pt footskip restores ~0.55in clear band.
\usepackage[margin=1in,top=1.25in,bottom=1.25in,footskip=30pt]{geometry}

% Font — Arial primary (matches URS-v1.0 Google-doc export, which was the
% deliverable shape the URS team produced and reviewed). Verdana available
% as a secondary fallback for systems without Arial (Verdana was the FDA-
% recommended sans-serif at one time; both are now acceptable for
% regulatory submission). DejaVu Sans final fallback for headless boxes.
\usepackage{fontspec}
\IfFontExistsTF{Arial}{
  \setmainfont{Arial}
}{
  \IfFontExistsTF{Verdana}{
    \setmainfont{Verdana}
  }{
    \setmainfont{DejaVu Sans}
  }
}
\setmonofont{DejaVu Sans Mono}[Scale=MatchLowercase]

\usepackage{microtype}
\usepackage{amssymb}
\usepackage[dvipsnames]{xcolor}

% Hyperlinks - clickable TOC and index
\usepackage[
  colorlinks=true,
  linkcolor=NavyBlue,
  urlcolor=NavyBlue,
  bookmarks=true,
  bookmarksnumbered=true,
  pdfstartview=FitH
]{hyperref}

% Long URLs break at any character (vs. only at /, ?, & with hyperref alone).
% Used for the JAMA Network / ASH Publications references on NOSE HHT / HHT-QoL
% True Copy assertions where the URL is longer than \linewidth. xurl loads
% AFTER hyperref so its breakpoints win.
\usepackage{xurl}

\usepackage{enumitem}

% Reserve a minimum amount of vertical space below a heading so a section
% heading can't be left orphaned at the bottom of a page with its first
% subsection content on the next page. Used via \needspace{Npt} in
% \titleformat hooks below. Round-2 audit caught orphan `7.2 Modals`,
% `7.3 Dialogs`, `7.4 Notifications` headings.
\usepackage{needspace}

% Suppress LaTeX hyphenation on words where the default hyphenation
% pattern produces awkward breaks ("Dia-log", "Prede-fined"). \hyphenation
% takes a list of hyphenation patterns — words listed with NO hyphens
% are never broken. Add words here as round-2 audit findings turn them up.
\hyphenation{Dialog Dialogs Predefined}

% Graphics support — every embedded image renders at a fixed fraction of
% the text column so screenshots / dialogs / phone mockups appear at a
% consistent visual size throughout the document. Round-2 audit found
% images ranging from ~40% to ~95% column width based on the source
% PNG's natural dimensions; pinning a single default removes that
% variance.
%
% Height cap kept at 0.85*\textheight as a safety: a figure sized to
% full textheight plus its caption (~14pt) plus float separation
% (\textfloatsep, ~24pt) would overflow the page and trigger "Float too
% large for page" warnings that bump the figure to a float page and
% strand the introducing prose ("Screen reference\n\nSee:") at the
% bottom of the previous page where it can overlap the footer rule.
\usepackage{graphicx}
\setkeys{Gin}{width=0.5\textwidth,height=0.85\textheight,keepaspectratio}

% Figure placement: `htbp` lets LaTeX pick the best of here/top/bottom/page
% so a figure that doesn't fit the immediate position can float to the next
% sensible slot rather than being forced (`H`) into a position that overlaps
% the page footer. The earlier `\floatplacement{figure}{H}` from the
% `float` package forced placement into the source position even when the
% available vertical space was insufficient — captions then collided with
% the `Specific to Protocol ... / CONFIDENTIAL / Page N of M` footer line
% on dense appendix pages (Ch6.3, Appendix B).
%
% Loosen the float-spacing knobs alongside so multi-image groups don't
% pack themselves against the body text / footer:
%   * \textfloatsep: gap between a top/bottom float and surrounding text.
%   * \floatsep:     gap between two floats on the same page.
%   * \intextsep:    gap above/below an in-line `[h]` float.
\usepackage{float}
\setlength{\textfloatsep}{24pt plus 4pt minus 4pt}
\setlength{\floatsep}{18pt plus 4pt minus 4pt}
\setlength{\intextsep}{18pt plus 4pt minus 4pt}
% Liberalize float-fraction limits so LaTeX doesn't reject placing a large
% screen-reference image at top/bottom of the same page as the introducing
% text. Defaults (\topfraction=0.7, \textfraction=0.2) are tuned for prose
% with small inset figures, not appendix screens that dominate the page.
\renewcommand{\topfraction}{0.9}
\renewcommand{\bottomfraction}{0.7}
\renewcommand{\textfraction}{0.1}
\renewcommand{\floatpagefraction}{0.7}

\usepackage{longtable,booktabs}

% Code blocks and syntax highlighting
\usepackage{fancyvrb}
\usepackage{framed}
\DefineVerbatimEnvironment{Highlighting}{Verbatim}{commandchars=\\\{\},fontsize=\small}
\newenvironment{Shaded}{\begin{snugshade}}{\end{snugshade}}
\definecolor{shadecolor}{RGB}{248,248,248}

% Pandoc syntax-highlighting tokens
\newcommand{\AlertTok}[1]{\textcolor[rgb]{1.00,0.00,0.00}{\textbf{#1}}}
\newcommand{\AnnotationTok}[1]{\textcolor[rgb]{0.38,0.63,0.69}{\textbf{\textit{#1}}}}
\newcommand{\AttributeTok}[1]{\textcolor[rgb]{0.49,0.56,0.16}{#1}}
\newcommand{\BaseNTok}[1]{\textcolor[rgb]{0.25,0.63,0.44}{#1}}
\newcommand{\BuiltInTok}[1]{#1}
\newcommand{\CharTok}[1]{\textcolor[rgb]{0.25,0.44,0.63}{#1}}
\newcommand{\CommentTok}[1]{\textcolor[rgb]{0.38,0.63,0.69}{\textit{#1}}}
\newcommand{\CommentVarTok}[1]{\textcolor[rgb]{0.38,0.63,0.69}{\textbf{\textit{#1}}}}
\newcommand{\ConstantTok}[1]{\textcolor[rgb]{0.53,0.00,0.00}{#1}}
\newcommand{\ControlFlowTok}[1]{\textcolor[rgb]{0.00,0.44,0.13}{\textbf{#1}}}
\newcommand{\DataTypeTok}[1]{\textcolor[rgb]{0.56,0.13,0.00}{#1}}
\newcommand{\DecValTok}[1]{\textcolor[rgb]{0.25,0.63,0.44}{#1}}
\newcommand{\DocumentationTok}[1]{\textcolor[rgb]{0.73,0.13,0.13}{\textit{#1}}}
\newcommand{\ErrorTok}[1]{\textcolor[rgb]{1.00,0.00,0.00}{\textbf{#1}}}
\newcommand{\ExtensionTok}[1]{#1}
\newcommand{\FloatTok}[1]{\textcolor[rgb]{0.25,0.63,0.44}{#1}}
\newcommand{\FunctionTok}[1]{\textcolor[rgb]{0.02,0.16,0.49}{#1}}
\newcommand{\ImportTok}[1]{\textcolor[rgb]{0.00,0.50,0.00}{\textbf{#1}}}
\newcommand{\InformationTok}[1]{\textcolor[rgb]{0.38,0.63,0.69}{\textbf{\textit{#1}}}}
\newcommand{\KeywordTok}[1]{\textcolor[rgb]{0.00,0.44,0.13}{\textbf{#1}}}
\newcommand{\NormalTok}[1]{#1}
\newcommand{\OperatorTok}[1]{\textcolor[rgb]{0.40,0.40,0.40}{#1}}
\newcommand{\OtherTok}[1]{\textcolor[rgb]{0.00,0.44,0.13}{#1}}
\newcommand{\PreprocessorTok}[1]{\textcolor[rgb]{0.74,0.48,0.00}{#1}}
\newcommand{\RegionMarkerTok}[1]{#1}
\newcommand{\SpecialCharTok}[1]{\textcolor[rgb]{0.25,0.44,0.63}{#1}}
\newcommand{\SpecialStringTok}[1]{\textcolor[rgb]{0.73,0.40,0.53}{#1}}
\newcommand{\StringTok}[1]{\textcolor[rgb]{0.25,0.44,0.63}{#1}}
\newcommand{\VariableTok}[1]{\textcolor[rgb]{0.10,0.09,0.49}{#1}}
\newcommand{\VerbatimStringTok}[1]{\textcolor[rgb]{0.25,0.44,0.63}{#1}}
\newcommand{\WarningTok}[1]{\textcolor[rgb]{0.38,0.63,0.69}{\textbf{\textit{#1}}}}

% URS-style header and footer
\usepackage{fancyhdr}
\usepackage{lastpage}
\usepackage{colortbl}  % for bordered + shaded tables (frontmatter + body)
\usepackage{array}      % for >{\centering\arraybackslash} columns
\usepackage{etoolbox}   % \pretocmd for page-break-before-REQ hook

% Shared colour for the header row of every grid table. The table-grid
% Lua filter (tools/pandoc-filters/table-grid.lua) rewrites body tables
% as longtables that reference this colour via `\rowcolor`.
\definecolor{tableHeaderShade}{gray}{0.88}
\arrayrulewidth=0.4pt

\pagestyle{fancy}
\fancyhf{}

% Three-line right-aligned header mirroring URS-v1.0 identity block
\fancyhead[R]{%
  \begin{tabular}{r@{}}
    \small \textbf{eCOA User Requirements Specification}\\
    \small Sponsor: [SPONSOR_NAME]\\
    \small Protocol: [PROTOCOL] \quad Version: 1.0
  \end{tabular}%
}

% CONFIDENTIAL marker left, "Page N of M" right
\fancyfoot[L]{\small Specific to Protocol [PROTOCOL]}
\fancyfoot[C]{\small CONFIDENTIAL}
\fancyfoot[R]{\small Page \thepage{} of \pageref{LastPage}}

\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}
\setlength{\headheight}{42pt}

% LaTeX uses \thispagestyle{plain} on chapter-start pages by default, which
% drops the fancyhdr header/footer. Override `plain` to use the same URS-
% identity header + CONFIDENTIAL footer so the branding is continuous from
% page 2 onward (cover is the only \thispagestyle{empty} page).
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyhead[R]{%
    \begin{tabular}{r@{}}
      \small \textbf{eCOA User Requirements Specification}\\
      \small Sponsor: [SPONSOR_NAME]\\
      \small Protocol: [PROTOCOL] \quad Version: 1.0
    \end{tabular}%
  }%
  \fancyfoot[L]{\small Specific to Protocol [PROTOCOL]}%
  \fancyfoot[C]{\small CONFIDENTIAL}%
  \fancyfoot[R]{\small Page \thepage{} of \pageref{LastPage}}%
  \renewcommand{\headrulewidth}{0.4pt}%
  \renewcommand{\footrulewidth}{0.4pt}%
}

% TOC number width — accommodate deep numbering like 3.11.18, but keep the
% nested indentation tight. Previous values (sec 2em / subsec 5.5em) pushed
% subsection titles far across the page; reviewers found the wraps awkward.
\usepackage[titles]{tocloft}
\setlength{\cftchapnumwidth}{2em}
\setlength{\cftsecnumwidth}{2.5em}
\setlength{\cftsubsecnumwidth}{3em}
\setlength{\cftsubsubsecnumwidth}{3.5em}
\setlength{\cftsecindent}{1em}
\setlength{\cftsubsecindent}{1.5em}
\setlength{\cftsubsubsecindent}{3em}

% Chapter/section formatting. Default `report` class renders chapter titles
% as a stacked "Chapter N\n\nTitle" block. URS-v1.0's Google-doc original
% used a single-line "N Title" form; titlesec's `[hang]` shape with the
% chapter number `\thechapter.` as the label (followed by a 0.5em gap)
% reproduces that look while keeping chapter numbers visible on the title
% page itself — the prior empty-label `{}` form hid numbers entirely so
% pages 12–14 ("Introduction and Purpose" etc.) appeared unnumbered even
% though the TOC and page headers referred to them as "1", "2", "3".
\usepackage{titlesec}
\titleformat{\chapter}[hang]{\Huge\bfseries}{\thechapter.}{0.5em}{}
\titlespacing*{\chapter}{0pt}{-20pt}{20pt}
\titleformat{\paragraph}[hang]{\normalfont\normalsize\bfseries}{}{0pt}{}
\titlespacing*{\paragraph}{0pt}{10pt}{4pt}

% Keep section / subsection headings from being orphaned at the bottom of a
% page. \needspace{6\baselineskip} reserves ~6 lines so the heading can't
% land with only its label visible before the page break.
\pretocmd{\section}{\needspace{6\baselineskip}}{}{}
\pretocmd{\subsection}{\needspace{6\baselineskip}}{}{}

% Each REQUIREMENT renders as `### Title` -> \subsection. Start every
% REQ on a fresh page so reviewers can read one requirement at a time
% without scrolling across boundaries. \newpage in the title-format's
% before-code block fires for every subsection.
\titleformat{\subsection}[hang]
  {\newpage\Large\bfseries}{\thesubsection.}{0.5em}{}

% Paragraph spacing
\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}

% Tight list support (pandoc)
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

% pandoc 3.x wraps included images in \pandocbounded for sizing. Newer
% reference templates define it; our template predates that. A simple
% passthrough definition is sufficient — the image \includegraphics
% calls already carry explicit width/keepaspectratio via pandoc's
% Image-to-LaTeX path, so we don't need pandocbounded's scaling logic.
\providecommand{\pandocbounded}[1]{#1}

% Title page
\title{$title$}
\date{\today}

\begin{document}

% Cover page: when --cover is provided, \input the LaTeX file. When no
% cover is provided, NO title page renders — the document opens directly
% on the TOC (if any) or the body. This supports the multi-stage compile
% in tools/compile-urs.sh, which generates the cover-and-frontmatter
% half via pandoc directly and produces the diary / callisto bodies via
% elspais pdf WITHOUT --cover so they don't render interstitial title
% pages when merged.
$if(cover-tex)$
\input{$cover-tex$}
\clearpage
$endif$

% Table of contents
$if(toc)$
\tableofcontents
\clearpage
$endif$

$body$

\end{document}
