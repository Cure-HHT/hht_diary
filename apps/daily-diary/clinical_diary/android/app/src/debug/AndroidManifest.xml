<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- DEBUG ONLY: allow cleartext (plain http) so a debug build can reach a
         local-stack portal server over `adb reverse` (http://localhost:8084).
         This manifest is merged into debug builds only — release/qa/uat/prod
         APKs never include it. -->
    <application
        android:usesCleartextTraffic="true"
        tools:replace="android:usesCleartextTraffic"/>
</manifest>
