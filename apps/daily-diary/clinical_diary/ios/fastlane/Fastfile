default_platform(:ios)

FLUTTER_DIR = File.expand_path("../../", __dir__)

PROFILE_NAMES = {
  "dev"  => "ClinicalDiary_DEV_AppStore",
  "qa"   => "ClinicalDiary_QA_AppStore",
  "uat"  => "ClinicalDiary_UAT_AppStore",
  "prod" => "ClinicalDiary_PROD_AppStore"
}

APP_IDENTIFIERS = {
  "dev"  => "org.anspar.curehht.app.dev",
  "qa"   => "org.anspar.curehht.app.qa",
  "uat"  => "org.anspar.curehht.app.uat",
  "prod" => "org.anspar.curehht.app"
}

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build DEV IPA"
  lane :build_dev do
    archive_once
    package_flavor(flavor: "dev")
  end

  desc "Build QA IPA"
  lane :build_qa do
    archive_once
    package_flavor(flavor: "qa")
  end

  desc "Build UAT IPA"
  lane :build_uat do
    archive_once
    package_flavor(flavor: "uat")
  end

  desc "Build PROD IPA"
  lane :build_prod do
    archive_once
    package_flavor(flavor: "prod")
  end

  desc "Build all four IPAs from one Dart compilation"
  lane :build_all do
    archive_once
    APP_IDENTIFIERS.each_key { |flavor| package_flavor(flavor: flavor) }
  end

  # Implements: DIARY-OPS-single-promotable-artifact/C
  # Prime the iOS project configuration once per Fastlane invocation, with no
  # flavor selected. The Dart source feeding the subsequent xcodebuild archives
  # is environment-independent (CUR-1389: no --dart-define=APP_FLAVOR; env is
  # resolved at runtime from assets/config/env.json), so the AOT snapshot each
  # xcodebuild archive emits is the same compilation across all four packages.
  private_lane :archive_once do
    Dir.chdir(FLUTTER_DIR) do
      sh("flutter", "build", "ios", "--release", "--config-only")
    end
  end

  private_lane :package_flavor do |options|
    flavor = options[:flavor]
    app_id = APP_IDENTIFIERS[flavor]
    profile_name = PROFILE_NAMES[flavor]

    # Required env vars — fail loudly if missing so misconfiguration surfaces early.
    apple_team_id = ENV.fetch("APPLE_TEAM_ID")
    cert_b64 = ENV.fetch("IOS_DISTRIBUTION_CERT_BASE64")
    cert_password = ENV.fetch("IOS_DISTRIBUTION_CERT_PASSWORD")
    profile_env_key = "IOS_PROVISIONING_PROFILE_#{flavor.upcase}_BASE64"
    profile_b64 = ENV.fetch(profile_env_key)

    # Import distribution certificate from Doppler env var into CI keychain
    cert_path = File.join(Dir.tmpdir, "distribution.p12")
    File.write(cert_path, Base64.decode64(cert_b64))
    import_certificate(
      certificate_path: cert_path,
      certificate_password: cert_password,
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ""
    )

    # Install provisioning profile from Doppler env var
    profile_path = File.join(Dir.tmpdir, "profile_#{flavor}.mobileprovision")
    File.write(profile_path, Base64.decode64(profile_b64))
    install_provisioning_profile(path: profile_path)

    # Switch Xcode project to manual signing for the Runner target
    update_code_signing_settings(
      use_automatic_signing: false,
      path: File.join(FLUTTER_DIR, "ios", "Runner.xcodeproj"),
      team_id: apple_team_id,
      bundle_identifier: app_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name
    )

    # Implements: DIARY-DEV-runtime-environment-resolution/E
    # Stamp the bundled env pointer (env name == flavor name); restored after
    # the archive so the working tree stays clean. The pointer flows into the
    # asset bundle that xcodebuild assembles below; changing it does not
    # invalidate the Dart AOT produced by archive_once.
    env_json = File.join(FLUTTER_DIR, "assets", "config", "env.json")
    File.write(env_json, "{ \"env\": \"#{flavor}\" }\n")

    # Copy the per-flavor Firebase config over the tracked top-level plist.
    # Replaces the dead $CONFIGURATION-keyed "Firebase Setup" Xcode build
    # phase that the pbxproj cleanup removed; restored alongside env.json so
    # the working tree stays clean.
    gs_src = File.join(FLUTTER_DIR, "ios", "Runner", flavor, "GoogleService-Info.plist")
    gs_dst = File.join(FLUTTER_DIR, "ios", "Runner", "GoogleService-Info.plist")
    FileUtils.cp(gs_src, gs_dst)

    begin
      # Archive and export IPA with Fastlane gym. The Runner scheme + Release
      # configuration is shared across all four flavors; per-env identity
      # (bundle id, signing, launcher icon, Firebase plist, env.json) is
      # injected via update_code_signing_settings, FileUtils.cp, the env.json
      # stamp above, and the ASSETCATALOG_COMPILER_APPICON_NAME xcarg. The
      # Dart source is the same across all four flavors (CUR-1389), so the
      # resulting App.framework/App is the same compilation regardless of
      # how many times xcodebuild is invoked.
      build_app(
        workspace: File.join(FLUTTER_DIR, "ios", "Runner.xcworkspace"),
        scheme: "Runner",
        configuration: "Release",
        export_method: "app-store",
        output_directory: File.join(FLUTTER_DIR, "build", "ios", "ipa"),
        output_name: "clinical-diary-#{flavor}.ipa",
        xcargs: "ASSETCATALOG_COMPILER_APPICON_NAME=#{flavor}AppIcon",
        export_options: {
          signingStyle: "manual",
          teamID: apple_team_id,
          provisioningProfiles: {
            app_id => profile_name
          }
        }
      )

      # Upload to TestFlight (CI only)
      deployment = ENV["DEPLOYMENT_TARGET"] || "none"
      if ENV["CI"] && deployment != "none"
        api_key_b64 = ENV.fetch("APP_STORE_CONNECT_API_KEY_MGR_BASE64")
        api_key_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_MGR_ID")
        api_issuer_id = ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID")

        api_key_path = File.join(Dir.tmpdir, "AuthKey.p8")
        File.write(api_key_path, Base64.decode64(api_key_b64))

        api_key = app_store_connect_api_key(
          key_id: api_key_id,
          issuer_id: api_issuer_id,
          key_filepath: api_key_path
        )

        case deployment
        when "internal"
          upload_to_testflight(
            api_key: api_key,
            skip_waiting_for_build_processing: true,
            distribute_external: false,
            groups: ["Internal Testing"]
          )
        when "external"
          upload_to_testflight(
            api_key: api_key,
            skip_waiting_for_build_processing: true,
            distribute_external: true,
            groups: ["External Testing"]
          )
        when "release"
          release_notes = ENV["RELEASE_NOTES"] || ""
          upload_to_app_store(
            api_key: api_key,
            ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
            skip_metadata: false,
            skip_screenshots: true,
            release_notes: { "en-US" => release_notes },
            submit_for_review: true,
            automatic_release: false,
            force: true,
            precheck_include_in_app_purchases: false
          )
        end
      end
    ensure
      # Restore tracked files mutated above (env pointer + Firebase plist) so
      # the working tree is left clean. Tolerate a restore failure so it can't
      # mask the actual build/upload result — parity with
      # tool/_write_env_pointer.sh, which uses `git checkout ... || true`.
      begin
        sh("git", "-C", FLUTTER_DIR, "checkout", "--",
           "assets/config/env.json", "ios/Runner/GoogleService-Info.plist")
      rescue => e
        UI.important("working-tree restore failed (#{e.message}); leaving as-is")
      end
    end
  end
end
