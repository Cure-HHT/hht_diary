    {
      "name": "dev Debug",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": [
        "--dart-define=APP_FLAVOR=dev", // Ensure the app flavor is set to dev
        "--flavor",
        "dev"
      ],
      "program": "lib/main.dart",
      "env": {
        "IMPORT_FILE": "", // If you want to pass a JSON file dynamically, you can set it here
        "DEVICE": "chrome" // Example device, you can set this dynamically if needed
      }
    },
    {
      "name": "dev Profile",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": ["--flavor", "dev"],
      "program": "lib/main.dart"
    },
    {
      "name": "dev Release",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": ["--flavor", "dev"],
      "program": "lib/main.dart"
