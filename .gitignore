# =====================================
# GENERIC
# =====================================


# Database connection files
.env
.env.local
.env.*.local
.env.offline

# PostgreSQL
*.sql~
*.backup
*.dump
database/init-consolidated.sql

# IDE and editor files - allow run/launch configs, ignore workspace-specific
# VS Code - allow launch.json for shared run configurations
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
# IntelliJ IDEA - allow run configurations, ignore user-specific files
.idea/*
!.idea/runConfigurations/
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
# Common editor files
*.swp
*.swo
*~
.DS_Store
.java-version

# Claude Code local settings
.claude/settings.local.json
.claude/permissions-registry.json

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Sensitive data
credentials.json
secrets/
*.key
*.pem
*.crt

# OS files
Thumbs.db
.Thumbs.db
desktop.ini

# =====================================
# BUILD ARTIFACTS
# =====================================
# Flutter/Dart
build/
# Exception: Allow build tools directory
!tools/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
flutter_*.log

# Flutter generated plugin registrants (regenerated by flutter pub get)
**/GeneratedPluginRegistrant.java
**/GeneratedPluginRegistrant.h
**/GeneratedPluginRegistrant.m
**/GeneratedPluginRegistrant.swift
**/generated_plugin_registrant.cc
**/generated_plugin_registrant.h
**/generated_plugins.cmake

# Stale generated report directories
build-reports/
validation-reports/

# Traceability matrices (generated by elspais)
traceability_matrix.csv
traceability_matrix.html
traceability_matrix.md
traceability.html
traceability.md

# iOS
*.ipa
*.app
*.dSYM.zip
*.dSYM
Pods/
.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/.symlinks/
**/ios/Podfile.lock

# macOS Flutter ephemeral (generated, contains machine-specific paths)
**/macos/Flutter/ephemeral/

# Android
*.apk
*.aab
*.ap_
*.dex
*.class
local.properties
**/android/captures/
**/android/.gradle/
**/android/gradle-wrapper.jar
**/android/key.properties

# Web
**/*.js.map
**/*.part

# =====================================
# NODE MODULES (for Edge Functions)
# =====================================
# We use npm: so that *is* tracked.
node_modules/
yarn.lock

# =====================================
# PYTHON (for tools)
# =====================================
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
ENV/
env/

# =====================================
# =====================================
#          PROJECT SPECIFIC           #
# =====================================
# =====================================

# =====================================
# Untracked notes and scratch files
/untracked-notes/

# =====================================
# SPONSOR ISOLATION (CRITICAL!)
# =====================================
# Ignore ALL sponsor directories by default to prevent accidental commits
# of locally cloned sponsor repos to core repo
sponsor/*/

# Exception: Track template 
!sponsor/template/

# **NOTE** 
# Temporarily tracking single sponsor in monorepo.
# Remove this when migrated to separat sponsor repos
!sponsor/callisto/

# =====================================
# SPONSOR-SPECIFIC SECRETS (CRITICAL!)
# =====================================
# Sponsor configuration secrets
sponsor/*/config/*.env
sponsor/*/config/supabase.env
sponsor/*/config/secrets.*
sponsor/*/config/.env*
sponsor/*/.env*

# Sponsor credentials and keys
sponsor/*/config/*.key
sponsor/*/config/*.pem
sponsor/*/config/credentials.*

# Sponsor build outputs (local testing)
sponsor/*/build/
sponsor/*/.dart_tool/
sponsor/*/.flutter-plugins
sponsor/*/.flutter-plugins-dependencies

untracked-notes/
/apps/daily-diary/clinical_diary/.firebase/
/infrastructure/sponsor-envs/package-lock.json


# =====================================
# TERRAFORM
# =====================================
# Local .terraform directories (plugins, modules)
**/.terraform/
**/.terraform.lock.hcl

# tfstate files - state is stored in GCS, not in repo
*.tfstate
*.tfstate.*

# Plan files
*.tfplan
tfplan
tfplan.*

# Crash log files
crash.log
crash.*.log

# Override files (for local testing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration file
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl SHOULD be committed for reproducible builds
# Do NOT ignore it!
