# IMPLEMENTS REQUIREMENTS:
#   REQ-d00059: Development Tool Specifications
#
# Central Version Pinning for All Environments
#
# This file defines version numbers used across:
# - GitHub Actions workflows
# - Docker development containers (ci, devops, audit)
# - CI/CD pipelines
# - Production container builds
#
# Last Updated: 2026-02-24

# ============================================================
# Language Runtimes
# ============================================================

# Node.js LTS (support until 2026-04-30)
NODE_VERSION=20
NODE_MAJOR_VERSION=20

# Flutter Stable (update quarterly)
FLUTTER_VERSION=3.38.7

# Dart SDK (for server containers - should match Flutter's bundled Dart)
DART_VERSION=3.10.7

# Python (Debian 12 default)
PYTHON_VERSION=3.11

# Java (OpenJDK - required for Android SDK / Firebase emulator)
JAVA_VERSION=17
OPENJDK_VERSION=17

# Ruby (for fastlane / cocoapods on iOS CI runners)
RUBY_VERSION=3.2

# ============================================================
# Cloud & Infrastructure
# ============================================================

# Google Cloud SQL Auth Proxy
CLOUD_SQL_PROXY_VERSION=2.14.3

# Terraform (latest 1.x via HashiCorp apt repo)
# Note: Installed via apt repo in devops.Dockerfile, not pinned to exact version here
# TERRAFORM_VERSION=latest-1.x

# ============================================================
# Android SDK
# ============================================================

ANDROID_CMDLINE_TOOLS_VERSION=11076708
ANDROID_BUILD_TOOLS_VERSION=34.0.0
ANDROID_PLATFORM_VERSION=34
ANDROID_CMAKE_VERSION=3.22.1

# ============================================================
# Database
# ============================================================

# PostgreSQL client version (for dev containers)
POSTGRESQL_CLIENT_VERSION=16

# PostgreSQL server (match production database version)
POSTGRES_VERSION=17
POSTGRES_IMAGE=postgres:17-alpine

# ============================================================
# Security & Compliance Tools
# ============================================================

# Gitleaks (secret scanning)
GITLEAKS_VERSION=8.29.0

# Squawk (PostgreSQL migration linter)
SQUAWK_VERSION=2.41.0

# Trivy (vulnerability scanner)
TRIVY_VERSION=0.34.0

# ============================================================
# CI/CD & Build Tools
# ============================================================

# Markdownlint CLI (documentation linting)
MARKDOWNLINT_CLI_VERSION=0.46.0

# Pandoc (URS PDF / DOCX compile via tools/compile-urs.sh).
# 3.9+ required: the table-grid Lua filter calls pandoc.write, added
# in pandoc 2.17; the project standardised on 3.9.0.2 as the first
# release ≥ that floor that's widely available as an upstream .deb.
# Install locally + in CI from the GitHub release:
#   wget https://github.com/jgm/pandoc/releases/download/${PANDOC_VERSION}/pandoc-${PANDOC_VERSION}-1-amd64.deb
#   sudo dpkg -i pandoc-${PANDOC_VERSION}-1-amd64.deb
PANDOC_VERSION=3.9.0.2

# GitHub CLI
GH_CLI_VERSION=latest

# elspais (requirement validation and traceability)
# Minimum version: 0.82.0 (hash mismatch returns non-zero exit code)
# Bumped to 0.117.0 (from 0.116.50) — minor release in the 0.117.x
# line; FederatedGraph composite-id behavior added in 0.115.x and
# stabilised through 0.116.x continues to apply.
ELSPAIS_VERSION=0.117.0

# anspar-wf (workflow plugins and MCP servers)
ANSPAR_WF_VERSION=0.1.0

# ============================================================
# Policy Flags
# ============================================================

# Code header validation: require IMPLEMENTS REQUIREMENTS in source files
#   off = skip check entirely (disabled)
#   on  = scan files, write report, fail the build if headers are missing
ENFORCE_CODE_HEADERS=off

# Database migration validation: run schema deploy + rollback tests
#   true  = run migration validation workflow
#   false = skip migration validation (e.g., during infrastructure-only PRs)
VALIDATE_MIGRATIONS=false
